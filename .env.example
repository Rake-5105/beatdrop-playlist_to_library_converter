# ──────────────────────────────────────────────────────────────
# BeatDrop — Environment Variables
# Copy this file to .env and fill in your credentials.
# ──────────────────────────────────────────────────────────────

# ── Spotify Developer Credentials ─────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard
# 2. Log in → Create App
#    - App name: anything (e.g. "BeatDrop")
#    - Redirect URI: http://localhost:3001  ← use this (localhost is allowed by Spotify)
#    NOTE: The redirect URI is NEVER used by this app (we use Client Credentials,
#          not user OAuth). Just fill it in so Spotify lets you save the form.
# 3. Copy Client ID and Client Secret below
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── YouTube Data API v3 ────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Enable APIs
# 3. Search "YouTube Data API v3" → Enable it
# 4. Credentials → Create Credentials → API Key → copy here
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Notes ──────────────────────────────────────────────────────
# - Spotify API is used for playlist METADATA only (track names, artists).
#   Audio is sourced from YouTube automatically.
# - YouTube quota: 10,000 units/day (free). Each playlist page = ~1 unit.
# - After editing .env, restart the server: npm run dev:full

# ── Server-side Spotify credentials (not exposed to browser) ──
# Mirror your Spotify credentials here without the VITE_ prefix.
# The backend reads these directly from process.env, keeping the
# client secret out of the bundled JavaScript.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── YouTube download cookies ───────────────────────────────────
# YouTube blocks yt-dlp as a bot unless it carries real browser cookies.
# Set this to the browser you use and are logged into YouTube with.
# Run a browser test to find the one that works on your machine:
#   node -e "require('child_process').spawn('server/yt-dlp.exe', ['--cookies-from-browser','firefox','https://www.youtube.com/watch?v=jNQXAC9IVRw','-O','title'], {stdio:'inherit'})"
# Options: firefox | chrome | edge | brave | chromium | safari
YOUTUBE_COOKIES_BROWSER=firefox
