# Copy this file to .env.local for local development.

# Frontend (Netlify) variable:
# Public backend URL used by the deployed frontend.
# This is NOT a secret. Set it in Netlify Environment Variables.
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Spotify app credentials used by the backend only.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional: browser whose YouTube cookies yt-dlp should use for downloads.
# Choose one: edge, chrome, firefox, brave, chromium, safari, opera, vivaldi, whale
# Leave commented out unless you actually need it locally.
# YOUTUBE_COOKIES_BROWSER=edge

# Backend (Render) CORS variables:
# Set these on Render for the backend service so your Netlify frontend can call it.
# FRONTEND_URL=https://your-site.netlify.app
# FRONTEND_ORIGINS=https://your-site.netlify.app,https://deploy-preview-1--your-site.netlify.app

# IMPORTANT:
# - Do NOT put VITE_* vars in Render backend env unless the backend code explicitly reads them.
# - Do NOT put Spotify secrets in Netlify frontend env.
